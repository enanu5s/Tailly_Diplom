# Базовый URL backend API (без завершающего слэша). В production обязателен.
VITE_API_BASE_URL=http://localhost:3000

# true — mock API и локальные данные; false — реальные запросы на VITE_API_BASE_URL
VITE_USE_MOCK_API=true

# Ключ 2GIS (карта, геоподсказки). Ограничьте домен в кабинете разработчика 2GIS.
# https://dev.2gis.com/
VITE_2GIS_API_KEY=82084c71-7147-49ff-a531-1bc80bfe76b3

# Email для отображения как контакт поддержки (опционально; иначе fallback в коде)
VITE_SUPPORT_EMAIL=support@tailly.ru
